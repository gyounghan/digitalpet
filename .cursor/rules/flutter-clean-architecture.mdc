// ❌ BAD - 레이어 경계 위반 (SharedPreferences 직접 사용)
class PetRepository {
  Future<void> save() {
    SharedPreferences.getInstance(); // Data 레이어 로직!
  }
}

// ❌ BAD - 주석 부족
class PetRepositoryImpl implements PetRepository {
  final PetLocalDataSource localDataSource;
  
  PetRepositoryImpl(this.localDataSource);
  
  Future<Pet> getPet(String id) async {
    return await localDataSource.getPet(id); // 주석 없음
  }
}

// ❌ BAD - Hive 초기화 누락
class PetLocalDataSource {
  Box<PetModel>? _box;
  
  Future<PetModel?> getPet(String id) async {
    return _box!.get(id); // 초기화 확인 없음
  }
